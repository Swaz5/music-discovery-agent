{"openapi":"3.1.0","info":{"title":"Music Discovery Agent API","description":"An agentic music discovery service powered by Claude. Submit a natural-language vibe description and receive curated artist and track recommendations drawn from Last.fm, Deezer, audio analysis, and a RAG knowledge base. Rate artists to build a personal taste profile that shapes future recommendations.","version":"1.0.0"},"paths":{"/discover":{"post":{"summary":"Discover","description":"Run the music discovery agent for a natural-language vibe query.\n\nWhen **stream=true** the response is a `text/event-stream` of JSON objects.\nEach event has a `type` field:\n\n- `start` — agent has begun processing\n- `reasoning_step` — one tool call from the agent's reasoning trace\n- `recommendations` — final list of recommendations\n- `done` — stream complete with token/iteration counts\n- `error` — unrecoverable failure","operationId":"discover_discover_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/DiscoverRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/DiscoverResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/artist/{name}":{"get":{"summary":"Get Artist","description":"Return full artist profile: bio, tags, similar artists, top tracks,\naveraged audio features, and social stats.","operationId":"get_artist_artist__name__get","parameters":[{"name":"name","in":"path","required":true,"schema":{"type":"string","title":"Name"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/explore":{"post":{"summary":"Explore Genre","description":"Explore a genre: returns knowledge base context, Last.fm top artists,\nand related genres inferred from the top artists' own genre tags.","operationId":"explore_genre_explore_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ExploreRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ExploreResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/rate":{"post":{"summary":"Rate Artist","description":"Save a preference rating for an artist.\n\nThe preference engine fetches audio features automatically if not supplied.\nReturns the updated taste profile summary.","operationId":"rate_artist_rate_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RateRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/RateResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/taste-profile":{"get":{"summary":"Get Taste Profile","description":"Return the current taste profile derived from all stored ratings.\n\nKeys: preferred_tags, preferred_audio, disliked_tags, disliked_audio,\nsweet_spots, total_ratings, liked_count, disliked_count, summary.","operationId":"get_taste_profile_taste_profile_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/history":{"get":{"summary":"Get History","description":"Return all discovery queries made during the current server session.","operationId":"get_history_history_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HistoryResponse"}}}}}}},"/analyze-taste":{"post":{"summary":"Analyze Taste","description":"Analyze a listener's taste from a list of artists they love.\n\nFetches full profiles for every artist in parallel, computes aggregate\naudio statistics (averages, variance, outliers, top tags), then asks\nClaude to identify patterns, name the taste identity, and — when\n**discover_blind_spots=true** — suggest unexplored genres the user\nwould likely enjoy.","operationId":"analyze_taste_analyze_taste_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AnalyzeTasteRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/AnalyzeTasteResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/bridge":{"post":{"summary":"Find Genre Bridge","description":"Discover the musical bridge between two genres.\n\nRuns a BFS through the Last.fm artist-similarity graph starting from the\ntop artists of **genre_a** and searching for paths that reach the top artists\nof **genre_b**. Each similarity edge is one \"hop\"; **max_hops** controls how\ndeep the search goes (1 = direct neighbours only, 3 = three steps deep).\n\nThe found paths, seed artists, and RAG knowledge base context for both genres\nare passed to Claude, which:\n- Selects the most musically meaningful bridge artists and explains *why* each\n  one sits at the intersection\n- Builds a transition playlist that moves smoothly from one genre to the other\n- Writes a paragraph explaining the historical/sonic connection\n\nThe endpoint is useful even when the graph finds no paths — Claude draws on\nits training knowledge grounded by the knowledge base context.","operationId":"find_genre_bridge_bridge_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/BridgeRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/BridgeResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/":{"get":{"tags":["health"],"summary":"Health Check","description":"Service liveness check.","operationId":"health_check__get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}}},"components":{"schemas":{"AnalyzeTasteRequest":{"properties":{"artists":{"items":{"type":"string"},"type":"array","maxItems":20,"minItems":1,"title":"Artists"},"discover_blind_spots":{"type":"boolean","title":"Discover Blind Spots","default":true}},"type":"object","required":["artists"],"title":"AnalyzeTasteRequest"},"AnalyzeTasteResponse":{"properties":{"taste_identity":{"type":"string","title":"Taste Identity"},"analysis":{"type":"string","title":"Analysis"},"common_threads":{"items":{"type":"string"},"type":"array","title":"Common Threads"},"audio_profile":{"additionalProperties":true,"type":"object","title":"Audio Profile"},"blind_spots":{"items":{"$ref":"#/components/schemas/BlindSpot"},"type":"array","title":"Blind Spots"},"outlier":{"anyOf":[{"$ref":"#/components/schemas/OutlierInfo"},{"type":"null"}]}},"type":"object","required":["taste_identity","analysis","common_threads","audio_profile","blind_spots","outlier"],"title":"AnalyzeTasteResponse"},"BlindSpot":{"properties":{"genre":{"type":"string","title":"Genre"},"why":{"type":"string","title":"Why"},"try_this":{"type":"string","title":"Try This"}},"type":"object","required":["genre","why","try_this"],"title":"BlindSpot"},"BridgeArtist":{"properties":{"name":{"type":"string","title":"Name"},"connects_because":{"type":"string","title":"Connects Because"},"genres":{"items":{"type":"string"},"type":"array","title":"Genres"}},"type":"object","required":["name","connects_because","genres"],"title":"BridgeArtist"},"BridgeRequest":{"properties":{"genre_a":{"type":"string","minLength":1,"title":"Genre A"},"genre_b":{"type":"string","minLength":1,"title":"Genre B"},"max_hops":{"type":"integer","maximum":5.0,"minimum":1.0,"title":"Max Hops","default":3}},"type":"object","required":["genre_a","genre_b"],"title":"BridgeRequest"},"BridgeResponse":{"properties":{"genre_a":{"type":"string","title":"Genre A"},"genre_b":{"type":"string","title":"Genre B"},"bridge_artists":{"items":{"$ref":"#/components/schemas/BridgeArtist"},"type":"array","title":"Bridge Artists"},"transition_playlist":{"items":{"$ref":"#/components/schemas/TransitionTrack"},"type":"array","title":"Transition Playlist"},"explanation":{"type":"string","title":"Explanation"}},"type":"object","required":["genre_a","genre_b","bridge_artists","transition_playlist","explanation"],"title":"BridgeResponse"},"DiscoverRequest":{"properties":{"query":{"type":"string","minLength":1,"title":"Query","description":"Natural-language vibe description"},"include_reasoning":{"type":"boolean","title":"Include Reasoning","description":"Include agent reasoning trace","default":false},"stream":{"type":"boolean","title":"Stream","description":"Stream response as Server-Sent Events","default":false}},"type":"object","required":["query"],"title":"DiscoverRequest"},"DiscoverResponse":{"properties":{"query":{"type":"string","title":"Query"},"recommendations":{"items":{"$ref":"#/components/schemas/RecommendationItem"},"type":"array","title":"Recommendations"},"reasoning_trace":{"anyOf":[{"items":{"additionalProperties":true,"type":"object"},"type":"array"},{"type":"null"}],"title":"Reasoning Trace"},"iterations":{"type":"integer","title":"Iterations"},"total_tokens":{"type":"integer","title":"Total Tokens"}},"type":"object","required":["query","recommendations","iterations","total_tokens"],"title":"DiscoverResponse"},"ExploreRequest":{"properties":{"genre":{"type":"string","minLength":1,"title":"Genre","description":"Genre name to explore"}},"type":"object","required":["genre"],"title":"ExploreRequest"},"ExploreResponse":{"properties":{"genre":{"type":"string","title":"Genre"},"knowledge_context":{"type":"string","title":"Knowledge Context"},"top_artists":{"items":{"additionalProperties":true,"type":"object"},"type":"array","title":"Top Artists"},"related_genres":{"items":{"type":"string"},"type":"array","title":"Related Genres"}},"type":"object","required":["genre","knowledge_context","top_artists","related_genres"],"title":"ExploreResponse"},"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"HistoryItem":{"properties":{"query":{"type":"string","title":"Query"},"recommendations":{"items":{"additionalProperties":true,"type":"object"},"type":"array","title":"Recommendations"},"iterations":{"type":"integer","title":"Iterations"},"total_tokens":{"type":"integer","title":"Total Tokens"},"timestamp":{"type":"number","title":"Timestamp"}},"type":"object","required":["query","recommendations","iterations","total_tokens","timestamp"],"title":"HistoryItem"},"HistoryResponse":{"properties":{"items":{"items":{"$ref":"#/components/schemas/HistoryItem"},"type":"array","title":"Items"},"total":{"type":"integer","title":"Total"}},"type":"object","required":["items","total"],"title":"HistoryResponse"},"OutlierInfo":{"properties":{"artist":{"type":"string","title":"Artist"},"why_different":{"type":"string","title":"Why Different"}},"type":"object","required":["artist","why_different"],"title":"OutlierInfo"},"RateRequest":{"properties":{"artist":{"type":"string","minLength":1,"title":"Artist"},"liked":{"type":"boolean","title":"Liked"},"notes":{"type":"string","title":"Notes","default":""}},"type":"object","required":["artist","liked"],"title":"RateRequest"},"RateResponse":{"properties":{"message":{"type":"string","title":"Message"},"taste_profile":{"additionalProperties":true,"type":"object","title":"Taste Profile"}},"type":"object","required":["message","taste_profile"],"title":"RateResponse"},"RecommendationItem":{"properties":{"artist":{"type":"string","title":"Artist"},"track":{"type":"string","title":"Track"},"genre_tags":{"items":{"type":"string"},"type":"array","title":"Genre Tags"},"why":{"type":"string","title":"Why"},"vibe_description":{"type":"string","title":"Vibe Description"},"vibe_match_score":{"type":"number","title":"Vibe Match Score"},"deezer_url":{"type":"string","title":"Deezer Url"}},"type":"object","required":["artist","track","genre_tags","why","vibe_description","vibe_match_score","deezer_url"],"title":"RecommendationItem"},"TransitionTrack":{"properties":{"track":{"type":"string","title":"Track"},"artist":{"type":"string","title":"Artist"},"position":{"type":"string","title":"Position"}},"type":"object","required":["track","artist","position"],"title":"TransitionTrack"},"ValidationError":{"properties":{"loc":{"items":{"anyOf":[{"type":"string"},{"type":"integer"}]},"type":"array","title":"Location"},"msg":{"type":"string","title":"Message"},"type":{"type":"string","title":"Error Type"},"input":{"title":"Input"},"ctx":{"type":"object","title":"Context"}},"type":"object","required":["loc","msg","type"],"title":"ValidationError"}}}}